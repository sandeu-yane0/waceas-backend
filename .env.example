# ── Base de données PostgreSQL Railway
DATABASE_URL=postgresql://user:password@host:5432/waceas_db

# ── JWT
SECRET_KEY=changez-cette-cle-secrete-minimum-32-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Premier admin (créé au démarrage)
FIRST_ADMIN_EMAIL=admin@waceas.com
FIRST_ADMIN_PASSWORD=WaceasAdmin2026!

# ── Cloudinary (récupérez ces valeurs sur cloudinary.com → Dashboard)
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ── CORS
ALLOWED_ORIGINS=https://waceas.com,https://waceas.com/admin,http://localhost:3001
